<!DOCTYPE html>
<html lang="ko">
<head>
<meta charset="UTF-8">
<style>
  @page {
    size: A4;
    margin: 20mm 15mm 20mm 15mm;
    @bottom-center {
      content: "Page " counter(page) " / " counter(pages);
      font-size: 9pt;
      color: #888;
    }
  }
  body {
    font-family: "Noto Sans CJK KR", "Malgun Gothic", "Apple SD Gothic Neo", sans-serif;
    font-size: 10pt;
    color: #222;
    line-height: 1.5;
  }
  h1 { font-size: 18pt; margin: 0 0 4px 0; }
  h2 { font-size: 12pt; margin: 16px 0 6px 0; border-bottom: 1px solid #ccc; padding-bottom: 3px; }
  .header { display: flex; justify-content: space-between; align-items: flex-start; margin-bottom: 12px; }
  .header-left h1 { color: #1a3a5c; }
  .header-left .subtitle { font-size: 9pt; color: #666; }
  .verdict-badge {
    font-size: 16pt;
    font-weight: bold;
    padding: 6px 18px;
    border-radius: 4px;
    text-align: center;
  }
  .verdict-pass  { background: #d4edda; color: #155724; border: 1px solid #c3e6cb; }
  .verdict-fail  { background: #f8d7da; color: #721c24; border: 1px solid #f5c6cb; }
  .verdict-error { background: #fff3cd; color: #856404; border: 1px solid #ffeeba; }

  table { width: 100%; border-collapse: collapse; font-size: 9pt; margin-bottom: 10px; }
  th { background: #1a3a5c; color: #fff; padding: 5px 8px; text-align: left; }
  td { padding: 4px 8px; border-bottom: 1px solid #e0e0e0; vertical-align: top; }
  tr:nth-child(even) td { background: #f8f9fa; }

  .status-pass  { color: #155724; font-weight: bold; }
  .status-fail  { color: #721c24; font-weight: bold; }
  .status-warn  { color: #856404; font-weight: bold; }

  .reason-list { margin: 4px 0; padding-left: 16px; }
  .reason-list li { margin-bottom: 2px; }
  .fail-box { background: #f8d7da; border-left: 3px solid #dc3545; padding: 6px 10px; margin-bottom: 8px; border-radius: 2px; }
  .warn-box { background: #fff3cd; border-left: 3px solid #ffc107; padding: 6px 10px; margin-bottom: 8px; border-radius: 2px; }
  .summary-box { background: #e8f4f8; border-left: 3px solid #17a2b8; padding: 6px 10px; border-radius: 2px; font-size: 9.5pt; }
  .meta-table td:first-child { color: #555; width: 120px; }
  .page-break { page-break-before: always; }
</style>
</head>
<body>

<!-- ─── 헤더 ─── -->
<div class="header">
  <div class="header-left">
    <h1>GPU 서버 검수 리포트</h1>
    <div class="subtitle">Server Inspection Report</div>
  </div>
  <div class="verdict-badge verdict-{{ overall }}">
    {% if overall == "pass" %}PASS ✓{% elif overall == "fail" %}FAIL ✗{% else %}ERROR{% endif %}
  </div>
</div>

<!-- ─── 기본 정보 ─── -->
<h2>기본 정보</h2>
<table class="meta-table">
  <tr><td>Job ID</td><td>{{ job_id }}</td></tr>
  <tr><td>대상 서버</td><td>{{ target_host }}</td></tr>
  <tr><td>접속 유저</td><td>{{ target_user }}</td></tr>
  <tr><td>제품 프로파일</td><td>{{ product_profile }}</td></tr>
  <tr><td>검수 시작</td><td>{{ created_at }}</td></tr>
  <tr><td>리포트 생성</td><td>{{ generated_at }}</td></tr>
</table>

<!-- ─── 판정 요약 ─── -->
<h2>판정 결과</h2>

{% if fail_reasons %}
<div class="fail-box">
  <strong>FAIL 사유</strong>
  <ul class="reason-list">
    {% for r in fail_reasons %}<li>{{ r }}</li>{% endfor %}
  </ul>
</div>
{% endif %}

{% if warn_reasons %}
<div class="warn-box">
  <strong>주의 사항</strong>
  <ul class="reason-list">
    {% for r in warn_reasons %}<li>{{ r }}</li>{% endfor %}
  </ul>
</div>
{% endif %}

{% if summary %}
<div class="summary-box">{{ summary }}</div>
{% endif %}

<!-- ─── 검수 항목별 결과 ─── -->
<h2>검수 항목 상세</h2>
<table>
  <thead>
    <tr>
      <th style="width:22%">스크립트</th>
      <th style="width:8%">상태</th>
      <th style="width:25%">Claude 판정</th>
      <th>상세</th>
    </tr>
  </thead>
  <tbody>
    {% for cr in check_results %}
    <tr>
      <td>{{ cr.check_name }}</td>
      <td class="status-{{ cr.status }}">{{ cr.status | upper }}</td>
      <td>{{ cr.claude_verdict or "—" }}</td>
      <td>{{ cr.detail }}</td>
    </tr>
    {% endfor %}
  </tbody>
</table>

</body>
</html>
