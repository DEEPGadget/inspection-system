{
  "profile_name": "gpu_server",
  "product_line": "gpu",
  "phases": {
    "phase2_sw_basic": {
      "enabled": true,
      "scripts": ["sw_cpu", "sw_memory", "sw_gpu", "sw_storage", "sw_network"]
    },
    "phase3_os_config": {
      "enabled": true,
      "scripts": ["sw_power_mgmt", "sw_auto_update"]
    },
    "phase4_stress": {
      "enabled": true,
      "scripts": ["stress_gpu", "stress_cpu"],
      "timeout": 7200,
      "env": {
        "GPU_BURNIN_DURATION": "300",
        "CPU_BURNIN_DURATION": "120"
      }
    },
    "phase5_nccl": {
      "enabled": true,
      "scripts": ["nccl_bandwidth"],
      "timeout": 120,
      "env": {
        "NCCL_ALLREDUCE_MIN_BW_2GPU": "30",
        "NCCL_ALLREDUCE_MIN_BW_4GPU": "5",
        "NCCL_TEST_SIZE": "1G"
      }
    },
    "phase6_sw_install": {
      "enabled": true,
      "scripts": ["sw_os_version"]
    },
    "phase7_collect": {
      "enabled": true,
      "scripts": ["collect_all_logs"]
    }
  },
  "temperature_thresholds": {
    "gpu_idle_max": 50,
    "gpu_load_max": 87,
    "cpu_idle_max": 55,
    "cpu_load_max": 100
  }
}
