# === 필수 ===
REDIS_URL=redis://redis:6379/0
DATABASE_URL=postgresql+asyncpg://inspector:changeme@db:5432/inspection
ANTHROPIC_API_KEY=sk-ant-...

# === NFS ===
NFS_BASE_PATH=/srv/inspection

# === Claude API ===
CLAUDE_MODEL=claude-sonnet-4-20250514
CLAUDE_MAX_TOKENS=4096

# === SSH ===
SSH_KEY_DIR=/etc/inspection/ssh_keys

# === WebSocket ===
WS_ENABLED=true
